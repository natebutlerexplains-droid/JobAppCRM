# Microsoft Graph API (Personal Outlook Account)
# Register at: https://portal.azure.com
# App type: Public client (native)
# Redirect URI: http://localhost:8400
MS_GRAPH_CLIENT_ID=your_client_id_here

# Google Gemini API
# Get free API key at: https://ai.google.dev
# Free tier: 60 requests/minute, 1,500/day
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Database
DATABASE_PATH=./jobs.db

# Email sync settings
EMAIL_SYNC_DAYS_BACK=30
SYNC_PROGRESS_EVERY=1

# Linking confidence threshold
# Emails with confidence below this are sent to unlinked tray
CONFIDENCE_THRESHOLD=0.7

# Logging level
LOG_LEVEL=INFO

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=false
VITE_API_BASE=http://localhost:5001/api
